{
  "name": "@stratawp/sync",
  "version": "0.1.0",
  "description": "Environment sync, snapshots, and rollback for StrataWP",
  "author": "Jon Imms",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./database": {
      "types": "./dist/database/index.d.ts",
      "import": "./dist/database/index.js",
      "require": "./dist/database/index.cjs"
    },
    "./snapshots": {
      "types": "./dist/snapshots/index.d.ts",
      "import": "./dist/snapshots/index.js",
      "require": "./dist/snapshots/index.cjs"
    },
    "./diff": {
      "types": "./dist/diff/index.d.ts",
      "import": "./dist/diff/index.js",
      "require": "./dist/diff/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "chalk": "^5.3.0",
    "mysql2": "^3.9.0",
    "node-ssh": "^13.2.0",
    "ora": "^8.0.0",
    "php-serialize": "^5.0.0",
    "ssh2": "^1.15.0",
    "tar": "^6.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/ssh2": "^1.11.0",
    "@types/tar": "^6.1.11",
    "@vitest/coverage-v8": "^1.0.4",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "stratawp",
    "wordpress",
    "sync",
    "database",
    "rollback",
    "snapshots"
  ],
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/JonImmsWordpressDev/StrataWP.git",
    "directory": "packages/sync"
  }
}
